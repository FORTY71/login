{
  "version": 2,
  "routes": [
    {
      "src": "/index.php",
      "dest": "/api/index.js"
    },
    {
      "src": "/api.php",
      "dest": "/api/index.js"
    },
    {
      "src": "/login.php",
      "dest": "/api/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.js"
    }
  ]
}
